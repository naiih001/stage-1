generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id                 String   @id @db.Uuid
  name               String   @unique @db.VarChar
  gender             String   @db.VarChar
  genderProbability  Float    @map("gender_probability")
  age                Int
  ageGroup           String   @map("age_group") @db.VarChar
  countryId          String   @map("country_id") @db.VarChar(2)
  countryName        String   @map("country_name") @db.VarChar
  countryProbability Float    @map("country_probability")
  createdAt          DateTime @default(now()) @map("created_at")

  @@index([gender])
  @@index([ageGroup])
  @@index([countryId])
  @@index([age])
  @@index([createdAt])
  @@index([gender, countryId, age])
  @@map("profiles")
}

enum Role {
  ANALYST
  ADMIN
}

model User {
  id            String         @id @db.Uuid
  githubId      String         @unique @map("github_id")
  username      String         @unique
  email         String?
  avatarUrl     String?        @map("avatar_url")
  role          Role           @default(ANALYST)
  isActive      Boolean        @default(true) @map("is_active")
  lastLoginAt   DateTime?      @map("last_login_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @db.Uuid
  token     String   @unique
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}
