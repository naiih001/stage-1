{
  "name": "stage-1",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate deploy",
    "prisma:seed": "node prisma/seed.js",
    "prisma:seed:profiles": "SEED_FILE=${SEED_FILE:-prisma/seed_profiles.json} node prisma/seed.js",
    "prisma:seed:dev": "DATABASE_URL=${DATABASE_URL_DEV:-postgresql://postgres:password@localhost:5432/profile_db?schema=public} SEED_FILE=${SEED_FILE:-prisma/seed_profiles.json} node prisma/seed.js",
    "prisma:migrate:prod": "DATABASE_URL=${DATABASE_URL_PROD:-${DATABASE_URL:?DATABASE_URL or DATABASE_URL_PROD is required}} npx prisma migrate deploy",
    "prisma:seed:prod": "DATABASE_URL=${DATABASE_URL_PROD:-${DATABASE_URL:?DATABASE_URL or DATABASE_URL_PROD is required}} SEED_FILE=${SEED_FILE:-prisma/seed_profiles.json} node prisma/seed.js",
    "prisma:deploy:prod": "DATABASE_URL=${DATABASE_URL_PROD:-${DATABASE_URL:?DATABASE_URL or DATABASE_URL_PROD is required}} npx prisma migrate deploy && DATABASE_URL=${DATABASE_URL_PROD:-${DATABASE_URL:?DATABASE_URL or DATABASE_URL_PROD is required}} SEED_FILE=${SEED_FILE:-prisma/seed_profiles.json} node prisma/seed.js",
    "prisma:stduio": "npx prisma studio",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "axios": "^1.15.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuidv7": "^1.2.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.19",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.3.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
